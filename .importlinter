# 依赖边界机器规则(见 AGENTS.md 三)。跑: lint-imports
#
# import-linter 2.x 的 forbidden contract 不支持把外部包子模块(如 src.config、
# src.core.storage.es)作为 forbidden module;同时本项目又需要允许少数 adapter import
# src.* 白名单模块。因此 rag 白名单与黑名单均由 tests/test_import_boundary.py 的源码扫描
# 强制。这里保留 import-linter 项目入口,确保工具在 CI 中可执行;若后续需要检查
# linkrag_eval 包内分层,在本文件新增只涉及 linkrag_eval.* 的 contract。

[importlinter]
root_package = linkrag_eval
include_external_packages = True
