# LinkRag-Eval 配置样例。真值复制到 .env.eval(gitignored),绝不提交。

# —— Qdrant(同 host,eval 独立前缀;前缀必须含 'eval')——
EVAL_QDRANT_HOST=http://103.205.254.30:36333
EVAL_QDRANT_PREFIX=eval_kb_bucket
EVAL_QDRANT_BUCKET_COUNT=16
EVAL_SPARSE_VECTOR_NAME=sparse_text

# —— eval 自持元数据/结果库(MySQL:同生产服务器、独立库 tolink_rag_eval_db)——
# 复用生产服务器/账号,只换库名;先建库:
#   CREATE DATABASE IF NOT EXISTS tolink_rag_eval_db
#     DEFAULT CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
EVAL_DB_HOST=103.205.254.30
EVAL_DB_PORT=33306
EVAL_DB_USER=root
EVAL_DB_PASSWORD=
EVAL_DB_NAME=tolink_rag_eval_db
# 或直接给完整 DSN 覆盖上面字段(mysql+aiomysql):
# EVAL_DB_URL=mysql+aiomysql://root:pass@103.205.254.30:33306/tolink_rag_eval_db?charset=utf8mb4

# —— judge LLM(已解耦,纯环境变量;api_key 绝不打印)——
EVAL_JUDGE_BASE_URL=
EVAL_JUDGE_API_KEY=
EVAL_JUDGE_MODEL=

# —— dense embedder(eval 自带 llm 模块,OpenAI 兼容 /embeddings;写入与召回 query 同一份)——
EVAL_EMBED_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EVAL_EMBED_API_KEY=
EVAL_EMBED_MODEL=text-embedding-v4
EVAL_EMBED_DIM=1024
EVAL_EMBED_BATCH_SIZE=10

# —— sparse 编码器(eval 自带 llm 模块,模型可选;api_key 绝不打印/提交)——
# 推荐 bge_m3_http:对齐生产系统级 sparse(BGE-M3 HTTP 服务),无需 key。
# 端点须含路径 /encode(服务路由);body {"texts":[...],"return_sparse":true} → {"sparse":[{token:weight}]}
EVAL_SPARSE_PROVIDER=bge_m3_http
EVAL_SPARSE_BASE_URL=http://103.205.254.30:37997/encode
EVAL_SPARSE_MODEL=BAAI/bge-m3
EVAL_SPARSE_TOP_K=256
EVAL_SPARSE_MIN_WEIGHT=0.0
# 备选 ark(火山方舟 doubao-vision,需 key):
# EVAL_SPARSE_PROVIDER=ark
# EVAL_SPARSE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/embeddings/multimodal
# EVAL_SPARSE_API_KEY=
# EVAL_SPARSE_MODEL=doubao-embedding-vision-251215

# —— 召回分路与融合参数 ——
# 2026-07-02 四域 394 条活栈调参:
# - RRF 最优: dense_top_k=20 / sparse_top_k=5 / dense_th=0.30 / sparse_th=0.40
# - weighted_score 最优: dense_top_k=150 / sparse_top_k=50 / dense_th=0.20 / sparse_th=0.40
# 当前默认采用 weighted_score;短 query 下 sparse 低权重辅助 dense。
EVAL_RECALL_DENSE_SCORE_THRESHOLD=0.20
EVAL_RECALL_SPARSE_SCORE_THRESHOLD=0.40
EVAL_RECALL_DENSE_TOP_K=150
EVAL_RECALL_SPARSE_TOP_K=50
EVAL_RECALL_FUSION_STRATEGY=weighted_score
EVAL_RECALL_DENSE_WEIGHT=0.90
EVAL_RECALL_SPARSE_WEIGHT=0.10
EVAL_RECALL_BM25_WEIGHT=0.0

# —— 路由常量(非真实用户,仅用于 bucket 分区)——
EVAL_USER_ID=990001

# —— bm25 模式:stub | sparse_proxy | qdrant_bm25 ——
EVAL_BM25_MODE=stub
