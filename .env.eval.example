# LinkRag-Eval 配置样例。真值复制到 .env.eval(gitignored),绝不提交。

# —— Qdrant(同 host,eval 独立前缀;前缀必须含 'eval')——
EVAL_QDRANT_HOST=http://103.205.254.30:36333
EVAL_QDRANT_PREFIX=eval_kb_bucket
EVAL_QDRANT_BUCKET_COUNT=16
EVAL_SPARSE_VECTOR_NAME=sparse_text
EVAL_QDRANT_BM25_COLLECTION=eval_bm25
EVAL_QDRANT_BM25_VECTOR_NAME=bm25_text
EVAL_BM25_SQLITE_PATH=runs/bm25_eval.sqlite3

# —— eval 自持元数据/结果库(MySQL:同生产服务器、独立库 tolink_rag_eval_db)——
# 复用生产服务器/账号,只换库名;先建库:
#   CREATE DATABASE IF NOT EXISTS tolink_rag_eval_db
#     DEFAULT CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
EVAL_DB_HOST=103.205.254.30
EVAL_DB_PORT=33306
EVAL_DB_USER=root
EVAL_DB_PASSWORD=
EVAL_DB_NAME=tolink_rag_eval_db
# 或直接给完整 DSN 覆盖上面字段(mysql+aiomysql):
# EVAL_DB_URL=mysql+aiomysql://root:pass@103.205.254.30:33306/tolink_rag_eval_db?charset=utf8mb4

# —— judge LLM(已解耦,纯环境变量;api_key 绝不打印)——
EVAL_JUDGE_BASE_URL=https://api.deepseek.com/chat/completions
EVAL_JUDGE_API_KEY=
EVAL_JUDGE_MODEL=deepseek-v4-flash
EVAL_JUDGE_TIMEOUT_S=60
EVAL_JUDGE_MAX_RETRIES=2
EVAL_JUDGE_CONCURRENCY=4

# —— Query rewrite planner(独立实验配置,不读取生产 llm_user_config)——
# BASE_URL 必须是完整 OpenAI-compatible chat completions 端点。
EVAL_REWRITE_BASE_URL=https://api.deepseek.com/chat/completions
EVAL_REWRITE_API_KEY=
EVAL_REWRITE_MODEL=
EVAL_REWRITE_TIMEOUT_S=90
EVAL_REWRITE_MAX_RETRIES=3
EVAL_REWRITE_CONCURRENCY=4
EVAL_REWRITE_TEMPERATURE=0
EVAL_REWRITE_MAX_TOKENS=900
EVAL_REWRITE_PROMPT_VERSION=query-rewrite-v1

# —— rerank(独立于生产 per-user 配置;标准 Jina/Cohere 兼容 POST /rerank)——
# 先由三路 weighted_score 融合，再仅将候选 TopK 送入 rerank；绝不把三路原始 300 条直接送入。
# provider=dashscope 使用百炼原生嵌套请求；provider=standard 使用 Jina/Cohere 平铺请求。
EVAL_RERANK_PROVIDER=dashscope
# BASE_URL 可填完整 /rerank 或 /reranks，或 provider base（standard 时自动补 /rerank）。
# 百炼 qwen3-rerank 必须是完整 WorkspaceId 路由：
# https://{WorkspaceId}.cn-beijing.maas.aliyuncs.com/compatible-api/v1/reranks
EVAL_RERANK_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank
EVAL_RERANK_API_KEY=
EVAL_RERANK_MODEL=
EVAL_RERANK_TIMEOUT_MS=60000
EVAL_RERANK_MAX_CANDIDATES=80
# qwen3-rerank 单条最多 4,000 tokens；Top80 需要控制总输入预算。
EVAL_RERANK_MAX_DOCUMENT_CHARS=1200

# —— dense embedder(eval 自带 llm 模块,OpenAI 兼容 /embeddings;写入与召回 query 同一份)——
EVAL_EMBED_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EVAL_EMBED_API_KEY=
EVAL_EMBED_MODEL=text-embedding-v4
EVAL_EMBED_DIM=1024
EVAL_EMBED_BATCH_SIZE=10

# —— Golden V2 候选池 alt embedding(必须与 EVAL_EMBED_MODEL 不同源;不写正式 Qdrant)——
# provider=openai:OpenAI 兼容 /embeddings,需要 API_KEY。
# provider=bge_m3_http:BGE-M3 HTTP /encode,无需 API_KEY,请求 return_dense=true。
EVAL_ALT_EMBED_PROVIDER=bge_m3_http
EVAL_ALT_EMBED_BASE_URL=
EVAL_ALT_EMBED_API_KEY=
EVAL_ALT_EMBED_MODEL=BAAI/bge-m3
EVAL_ALT_EMBED_DIM=1024
EVAL_ALT_EMBED_BATCH_SIZE=10
EVAL_ALT_EMBED_SQLITE_PATH=runs/alt_embedding_eval.sqlite3

# —— sparse 编码器(eval 自带 llm 模块,模型可选;api_key 绝不打印/提交)——
# 推荐 bge_m3_http:对齐生产系统级 sparse(BGE-M3 HTTP 服务),无需 key。
# 端点须含路径 /encode(服务路由);body {"texts":[...],"return_sparse":true} → {"sparse":[{token:weight}]}
EVAL_SPARSE_PROVIDER=bge_m3_http
EVAL_SPARSE_BASE_URL=http://103.205.254.30:37997/encode
EVAL_SPARSE_MODEL=BAAI/bge-m3
EVAL_SPARSE_TOP_K=256
EVAL_SPARSE_MIN_WEIGHT=0.0
# 备选 ark(火山方舟 doubao-vision,需 key):
# EVAL_SPARSE_PROVIDER=ark
# EVAL_SPARSE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/embeddings/multimodal
# EVAL_SPARSE_API_KEY=
# EVAL_SPARSE_MODEL=doubao-embedding-vision-251215

# —— 召回分路与融合参数 ——
# 2026-07-15 20k realistic tune 最优 Hybrid:
# dense 150/.30/.70; sparse 50/.20/.15; BM25 100/.00/.15。
EVAL_RECALL_DENSE_SCORE_THRESHOLD=0.30
EVAL_RECALL_SPARSE_SCORE_THRESHOLD=0.20
EVAL_RECALL_BM25_TOP_K=100
EVAL_RECALL_DENSE_TOP_K=150
EVAL_RECALL_SPARSE_TOP_K=50
EVAL_RECALL_FUSION_STRATEGY=weighted_score
EVAL_RECALL_DENSE_WEIGHT=0.70
EVAL_RECALL_SPARSE_WEIGHT=0.15
EVAL_RECALL_BM25_WEIGHT=0.15

# —— 路由常量(非真实用户,仅用于 bucket 分区)——
EVAL_USER_ID=990001

# —— Qdrant BM25 参数:旧 qdrant_bm25 模式使用 ——
EVAL_BM25_K1=1.2
EVAL_BM25_B=0.75
EVAL_BM25_AVGDL=200.0
EVAL_BM25_AVGDL_FINE=220.0
EVAL_BM25_COARSE_BOOST=2.0

# —— SQLite FTS5 BM25 参数:新推荐模式使用 ——
EVAL_BM25_SQLITE_COARSE_WEIGHT=2.0
EVAL_BM25_SQLITE_FINE_WEIGHT=1.0

# —— bm25 模式:stub | qdrant_bm25 | sqlite_fts5。推荐 sqlite_fts5。 ——
EVAL_BM25_MODE=sqlite_fts5
