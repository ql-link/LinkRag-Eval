# LinkRag-Eval 配置样例。真值复制到 .env.eval(gitignored),绝不提交。

# —— Qdrant(同 host,eval 独立前缀;前缀必须含 'eval')——
EVAL_QDRANT_HOST=http://103.205.254.30:36333
EVAL_QDRANT_PREFIX=eval_kb_bucket
EVAL_QDRANT_BUCKET_COUNT=16

# —— eval 自持元数据/结果库(独立 Postgres 实例)——
EVAL_PG_DSN=postgresql+asyncpg://user:pass@host:5432/linkrag_eval

# —— judge LLM(已解耦,纯环境变量;api_key 绝不打印)——
EVAL_JUDGE_BASE_URL=
EVAL_JUDGE_API_KEY=
EVAL_JUDGE_MODEL=

# —— 系统 embedder(dense 写入与召回 query 编码必须用同一份)——
EVAL_EMBED_BASE_URL=
EVAL_EMBED_API_KEY=
EVAL_EMBED_MODEL=text-embedding-v4
EVAL_EMBED_DIM=1024

# —— 路由常量(非真实用户,仅用于 bucket 分区)——
EVAL_USER_ID=990001

# —— bm25 模式:stub | sparse_proxy | qdrant_bm25 ——
EVAL_BM25_MODE=stub
